{
  "sourceLanguage" : "en",
  "strings" : {
    "" : {

    },
    "." : {
      "comment" : "A dot character used in the onboarding import page to indicate a loading state.",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A label displaying the XP value associated with a specific quest tier. The argument is the XP value for the selected tier.",
      "isCommentAutoGenerated" : true
    },
    "%lld×/%@" : {
      "comment" : "A text displaying the current value of the weekly target, followed by a multiplier and a suffix. The first argument is the current value of the weekly target. The second argument is the suffix to append to the value.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld×/%2$@"
          }
        }
      }
    },
    "%lld×/wk" : {
      "comment" : "A label indicating that a quest can be completed multiple times within a week. The argument is the number of times the quest can be completed in a week.",
      "isCommentAutoGenerated" : true
    },
    "accessibility.hp.label" : {
      "comment" : "Voiceover label for the character's Health Points (HP) bar.",
      "isCommentAutoGenerated" : true
    },
    "accessibility.hp.value %lld %lld" : {
      "comment" : "A string that announces the current and maximum health points of the player character. The argument is the current health points, and the second is the maximum health points.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "accessibility.hp.value %1$lld %2$lld"
          }
        }
      }
    },
