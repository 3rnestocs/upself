    "onboarding.lockdown.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If your HP drops below 30%, distracting apps get blocked.\n\nIt's not a punishment — it's the consequence of breaking commitments. To exit, complete hard or epic quests.\n\nStarts from day one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tu HP baja del 30%, las apps distractoras quedan bloqueadas.\n\nNo es un castigo — es la consecuencia de incumplir compromisos. Para salir, completa misiones difíciles o épicas.\n\nAplica desde el primer día."
          }
        }
      }
    },
