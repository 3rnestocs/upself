    "onboarding.concept.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Committed quests have a weekly target — miss them and you lose HP. Freeform quests are optional. Goals are one-time milestones.\n\nLet's load your starter set now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las misiones comprometidas tienen un objetivo semanal — si no las cumples, pierdes HP. Las misiones libres son opcionales. Las metas son logros únicos.\n\nVamos a cargar tu set inicial ahora."
          }
        }
      }
    },
